# ==========================================
# Configurações Essenciais do Django
# ==========================================
# Gere uma chave segura e aleatória para produção.
DJANGO_SECRET_KEY=sua_chave_secreta_aqui

# Mude para False em ambiente de produção
DJANGO_DEBUG=True

# Chave de API interna do seu sistema (se houver)
DJANGO_API_KEY=sua_chave_de_api_interna

# Lista de domínios permitidos separados por vírgula (ex: localhost,127.0.0.1,meudominio.com)
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ==========================================
# Banco de Dados
# ==========================================
# Deixe em branco ou comentado para usar o SQLite local (padrão)
# Para produção (SQL Server/PostgreSQL), use o formato:
# DATABASE_URL=mssql://usuario:senha@ip_do_servidor:1433/nome_do_banco
# DATABASE_URL=postgres://usuario:senha@ip:5432/banco
DATABASE_URL=

# ==========================================
# Cache e Performance (Opcional)
# ==========================================
# Deixe em branco para usar o cache local de memória do Django.
# Para usar Redis, informe a URL:
# REDIS_URL=redis://127.0.0.1:6379/1
REDIS_URL=

# ==========================================
# Observabilidade e Logs (Opcional)
# ==========================================
# Link DSN fornecido pelo painel do Sentry para rastreamento de erros.
SENTRY_DSN=

# ==========================================
# Integrações Externas (APIs)
# ==========================================
# Token para consulta de feriados na API externa
FERIADOS_API_TOKEN=seu_token_da_api_de_feriados_aqui

# Configurações do Evolution API (WhatsApp)
WPP_API_TOKEN=seu_token_do_whatsapp_aqui
WPP_API_PORT=3000
WPP_BASE_URL=http://localhost:3000
